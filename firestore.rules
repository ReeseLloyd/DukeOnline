rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Game documents — anyone can read (to join or spectate);
    // only authenticated users can create; only a player in the game can write moves.
    match /games/{gameId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.player1Uid == request.auth.uid ||
        resource.data.player2Uid == request.auth.uid
      );
      allow delete: if false;
    }

  }
}
